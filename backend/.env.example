PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Optional: comma-separated list of allowed frontend origins for CORS.
# Without this, all origins are allowed (fine for local dev).
CORS_ORIGIN=

# Optional: directory for the SQLite database file. Useful in deployments
# where you mount a persistent disk (e.g. Render) at a custom path.
# Without this, defaults to backend/data.
DATA_DIR=

# Optional: enables Gemini-powered recommendations. Without it, the
# recommendations engine falls back to built-in heuristics.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Brevo (https://app.brevo.com) settings for sending password reset OTP emails.
# Without BREVO_API_KEY, emails are only logged to the server console.
# Get your API key from Brevo → Settings → SMTP & API → API Keys.
# EMAIL_FROM_ADDRESS must be a verified sender in your Brevo account.
BREVO_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Nexus
