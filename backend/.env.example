PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Optional: comma-separated list of allowed frontend origins for CORS.
# Without this, all origins are allowed (fine for local dev).
CORS_ORIGIN=

# Optional: directory for the SQLite database file. Useful in deployments
# where you mount a persistent disk (e.g. Render) at a custom path.
# Without this, defaults to backend/data.
DATA_DIR=

# Optional: enables Gemini-powered recommendations. Without it, the
# recommendations engine falls back to built-in heuristics.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# SMTP settings for sending password reset OTP emails.
# Without these, the OTP is only logged to the server console.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false,
# SMTP_USER=your@gmail.com, SMTP_PASS=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
